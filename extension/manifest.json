{
  "manifest_version": 3,
  "name": "루시퍼홍 부동산 도구모음",
  "version": "1.0.0",
  "description": "네이버부동산 단지라벨 색상변경 + 매물 가격 필터",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://new.land.naver.com/complexes*"],
      "js": ["scripts/naver-complex-label.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://new.land.naver.com/complexes*"],
      "js": [
        "vendor/jquery-1.12.4.min.js",
        "vendor/clipboard-2.0.10.min.js",
        "scripts/naver-price-filter.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
